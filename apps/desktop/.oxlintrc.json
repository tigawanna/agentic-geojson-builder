{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "out/**",
    "dist/**",
    "release/**",
    "node_modules/**",
    "playwright-report/**",
    "coverage/**"
  ],
  "env": {
    "builtin": true
  },
  "rules": {},
  "overrides": [
    {
      "files": ["tests/unit/setup.ts"],
      "rules": {
        "vitest/require-mock-type-parameters": "off"
      }
    }
  ]
}
